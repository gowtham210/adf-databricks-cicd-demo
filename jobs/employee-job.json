{
  "name": "Employee_ETL_Job",
  "tasks": [
    {
      "task_key": "CreateTables",
      "notebook_task": {
        "notebook_path": "/Shared/CICD/NB_CreateTables"
      },
      "job_cluster_key": "employee_cluster"
    },
    {
      "task_key": "LoadMetadata",
      "depends_on": [
        {
          "task_key": "CreateTables"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Shared/CICD/NB_LoadMetadata"
      },
      "job_cluster_key": "employee_cluster"
    },
    {
      "task_key": "LoadEmployee",
      "depends_on": [
        {
          "task_key": "LoadMetadata"
        }
      ],
      "notebook_task": {
        "notebook_path": "/Shared/CICD/NB_LoadEmployee"
      },
      "job_cluster_key": "employee_cluster"
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "employee_cluster",
      "new_cluster": {
        "spark_version": "16.4.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 1
      }
    }
  ]
}
